APP_NAME=Government AI Agent Service
APP_ENV=production
APP_VERSION=0.1.0

HOST=0.0.0.0
PORT=8080

# Required for /agent/* endpoints. Use Secret Manager in cloud deploy.
INTERNAL_API_KEY=from-secret-manager

AI_AGENT_DATA_SOURCE=bigquery
BIGQUERY_PROJECT_ID=western-pivot-452008-a6
BIGQUERY_LOCATION=asia-southeast1
BIGQUERY_GOLD_DATASET=gov_ai_gold
BIGQUERY_ANALYTICS_DATASET=gov_ai_analytics
BIGQUERY_MAX_BYTES_BILLED=100000000
BIGQUERY_CACHE_TTL_SECONDS=60

PIPELINE_MODE=hybrid_v2
ENABLE_HYBRID_V2_FALLBACK=true
HYBRID_V2_DEBUG=false

ENABLE_GEMINI=true
GEMINI_API_KEY=from-secret-manager
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_ROUTER_ENABLED=true
GEMINI_ROUTER_MODEL=gemini-3.1-flash-lite-preview
GEMINI_ROUTER_TIMEOUT_MS=10000
GEMINI_ROUTER_RETRIES=1
GEMINI_ROUTER_RETRY_BACKOFF_MS=700
GEMINI_COMPOSER_ENABLED=true
CONVERSATION_CONTEXT_MAX_ROWS=20

PARSER_SERVICE_BASE_URL=from-secret-manager
PARSER_SERVICE_API_KEY=from-secret-manager
PARSER_SERVICE_TIMEOUT_MS=45000
PARSER_MODE=hybrid
PARSER_DEBUG=false
PARSER_HYBRID_ALLOWED_INTENTS=COMPARE_COUNTRIES,RANKING,TIME_SERIES,TREND_ANALYSIS,VALUE_LOOKUP,COVERAGE,RANK_BY_CHANGE,COMPARE_INDICATORS,ANOMALY_DETECTION
